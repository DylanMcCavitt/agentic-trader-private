{
  "permissions": {
    "allow": [
      "Read",
      "Write(./state/artifacts/**)",
      "Write(./logs/**)",
      "Edit(./lanes/**)",
      "Write(/tmp/**)",
      "Bash(uv run trader:*)",
      "Bash(uv run python -m trader:*)",
      "Bash(uv run pytest:*)",
      "Bash(RUN_ID=$(uv run trader lane record-start:*)",
      "Bash(REF_ID=$(uuidgen))",
      "Bash(uuidgen)",
      "Bash(date:*)",
      "Bash(sleep:*)",
      "Bash(cat:*)",
      "Bash(bash ops/notify.sh:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch --show-current)",
      "Bash(BASE_BRANCH=$(git branch --show-current))",
      "Bash(git add lanes/:*)",
      "Bash(git switch:*)",
      "Bash(git checkout -b improve/:*)",
      "Bash(git checkout main)",
      "Bash(git commit:*)",
      "Bash(git merge improve/:*)",
      "WebSearch",
      "WebFetch",
      "mcp__claude_ai_Robinhood",
      "mcp__robinhood"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./config.local.json)",
      "Read(~/.secrets/**)",
      "Edit(./trader/envelope.py)",
      "Write(./trader/envelope.py)",
      "Edit(./trader/gates/**)",
      "Write(./trader/gates/**)",
      "Edit(./.claude/**)",
      "Write(./.claude/**)",
      "Edit(./ops/**)",
      "Write(./ops/**)",
      "Edit(./.github/**)",
      "Write(./.github/**)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*place_equity_order",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run python -m trader.gates.equity_gate"
          }
        ]
      },
      {
        "matcher": "mcp__.*place_option_order",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run python -m trader.gates.option_gate"
          }
        ]
      }
    ]
  }
}
