<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.agentic-trader.improve</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__WRAPPER__</string>
    <string>improve</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__DEPLOY_ROOT__</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Weekday</key><integer>6</integer><key>Hour</key><integer>10</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>StandardOutPath</key>
  <string>__DEPLOY_ROOT__/logs/launchd/com.agentic-trader.improve.log</string>
  <key>StandardErrorPath</key>
  <string>__DEPLOY_ROOT__/logs/launchd/com.agentic-trader.improve.log</string>
</dict>
</plist>
